{
  "name": "spriteforge",
  "version": "1.0.0",
  "description": "Generate game sprites using OpenAI's image generation API",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"npm run server\" \"npm run tailwind\"",
    "server": "nodemon server.js",
    "tailwind": "tailwindcss -i ./styles/input.css -o ./styles/output.css --watch",
    "build": "tailwindcss -i ./styles/input.css -o ./styles/output.css --minify",
    "test": "npm run check",
    "test:unit": "vitest run --config vitest.config.mjs --reporter=dot tests/unit",
    "test:integration": "vitest run --config vitest.config.mjs --reporter=dot tests/integration",
    "test:mock": "npm run test:unit && npm run test:integration",
    "test:ui": "vitest run --config vitest.config.mjs --environment jsdom --reporter=dot tests/ui",
    "validate": "node scripts/validate.mjs",
    "check:real-api": "node scripts/check-real-api.mjs",
    "check:openai-smoke": "node scripts/check-real-api.mjs",
    "check": "npm run build && npm run test:mock && npm run test:ui && node scripts/check-real-api.mjs",
    "postinstall": "npm run build",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d ."
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "http-server": "^14.1.1",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.28.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "gh-pages": "^6.1.1",
    "jsdom": "^26.1.0",
    "nodemon": "^3.0.3",
    "pngjs": "^7.0.0",
    "postcss": "^8.4.33",
    "postcss-cli": "^11.0.0",
    "tailwindcss": "^3.4.1",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18"
  }
}
